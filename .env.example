# Toronto Civic Risk Analyst — environment template.
# Copy to .env (`cp .env.example .env`) and adjust. All values are optional;
# the app is offline-safe and falls back to deterministic output with no model.
# pydantic-settings reads these case-insensitively (see src/civic_analyst/config.py).

# --- Local LLM (OpenAI-compatible endpoint) ---------------------------------
# Dev: Ollama at :11434/v1. On the GX10/GB10: point at the local NIM/TRT-LLM server.
LLM_BASE_URL=http://localhost:11434/v1
# Placeholder credential for local OpenAI-compatible servers (Ollama ignores it).
# NEVER put a real secret here — .env is gitignored, this template is committed.
LLM_API_KEY=ollama
# Which runtime serves the endpoint: ollama | tensorrt-llm | nim | vllm
LLM_RUNTIME=ollama
# Interactive narrator model (dev: llama3.2:3b; box: nemotron-3-nano).
LLM_MODEL=nemotron-3-nano
# Heavier batch/reasoning model for /digest (box: gpt-oss:120b or nemotron3:33b).
LLM_BATCH_MODEL=nemotron3:33b
# Reasoning effort for the interactive narrator: none | low | medium | high | ""
LLM_REASONING_EFFORT=none
# Warm the model at boot so the first /analyze isn't paying cold-load. Off for CI.
LLM_PREWARM=true

# --- Data -------------------------------------------------------------------
# City of Toronto CKAN open-data endpoint.
CKAN_BASE_URL=https://ckan0.cf.opendata.inter.prod-toronto.ca
# Where raw downloaded datasets land (gitignored). The demo uses demo_data/ / fixtures/.
DATA_DIR=./data/raw
